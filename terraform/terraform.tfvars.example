# Copy to terraform.tfvars and edit. terraform.tfvars is auto-loaded.
# Do NOT commit terraform.tfvars if it contains anything sensitive.

aws_region       = "us-east-1"
instance_type    = "t3.micro"
allowed_ssh_cidr = "1.2.3.4/32"  # replace with your public IP/32
key_name       = "my-devops-app-key"